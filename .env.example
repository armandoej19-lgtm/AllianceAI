# ==============================================================================
# AllianceAI configuration (loaded automatically via pydantic-settings)
# Copy this file to `.env` and fill in your own keys. Do NOT commit `.env`.
# ==============================================================================

# ------------------------------------------------------------------
# LLM highlights provider
#   anthropic  -> Claude API directly (set ANTHROPIC_API_KEY)
#   openrouter -> any model via OpenRouter (set OPENROUTER_API_KEY)
#   auto       -> anthropic if its key is set, else openrouter, else fallback
#   none       -> rule-based highlights only, no API calls
# ------------------------------------------------------------------
LLM_PROVIDER=auto

# --- Anthropic (https://console.anthropic.com/settings/keys) ---
ANTHROPIC_API_KEY=
HIGHLIGHTS_MODEL=claude-haiku-4-5

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=
# Any OpenRouter model id works, e.g.:
#   anthropic/claude-haiku-4.5      (recommended: cheap + good)
#   meta-llama/llama-3.3-70b-instruct
#   google/gemini-2.0-flash-001
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ------------------------------------------------------------------
# SEC EDGAR — set a real contact per SEC fair-access rules
# ------------------------------------------------------------------
EDGAR_USER_AGENT=AllianceAI research tool (contact: your-email@example.com)
EDGAR_MIN_PERIODS=12

# ------------------------------------------------------------------
# Other knobs (defaults shown)
# ------------------------------------------------------------------
# DB_PATH=allianceai.duckdb
# CACHE_TTL_HOURS=24
# FORECAST_HORIZON_QUARTERS=8
